nftfract.duckdns.org {
    # Allow search engine crawlers
    @bots {
        header User-Agent *Googlebot*
        header User-Agent *bingbot*
    }
    
    # Frontend
    handle {
        reverse_proxy frontend:80
    }

    # Backend API
    handle /api/* {
        reverse_proxy backend:4000
    }

    # Backend health check
    handle /health {
        reverse_proxy backend:4000
    }
}
